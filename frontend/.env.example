# Copy to frontend/.env and fill in. All values are exposed to the client (Vite VITE_ prefix).
# Defaults in src/chain/config.ts already target Osmosis testnet (osmo-test-5), so to confirm
# reads you really only need VITE_CONTRACT_ADDRESS and VITE_PROPOSAL_ID.

# ---- usually the only two you must set ----
# The petri-market contract address printed by scripts/deploy.sh
VITE_CONTRACT_ADDRESS=
# The governance proposal this dish tracks
VITE_PROPOSAL_ID=

# ---- chain (override only if not using the osmo-test-5 defaults) ----
# VITE_CHAIN_ID=osmo-test-5
# VITE_CHAIN_NAME=Osmosis Testnet
# VITE_RPC_ENDPOINT=https://rpc.osmotest5.osmosis.zone
# VITE_REST_ENDPOINT=https://lcd.osmotest5.osmosis.zone
# VITE_BECH32_PREFIX=osmo
# VITE_COIN_TYPE=118

# ---- denom (override only if not uosmo) ----
# VITE_DENOM=uosmo
# VITE_DENOM_DISPLAY=OSMO
# VITE_DENOM_DECIMALS=6

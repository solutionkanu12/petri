# Copy to scripts/.env, fill in, then:  source scripts/.env
# NEVER commit a real mnemonic. scripts/.env is gitignored.

# ---- required ----
# Seed phrase of the deployer, which becomes the market admin (can call Resolve).
# Use a throwaway testnet account, not a wallet holding anything real.
export MNEMONIC="word1 word2 ... word24"

# ---- chain (defaults are Osmosis testnet osmo-test-5) ----
export CHAIN_ID="osmo-test-5"
export RPC="https://rpc.osmotest5.osmosis.zone:443"
export DENOM="uosmo"

# ---- key handling ----
# 'test' backend stores keys unencrypted on disk — fine for a testnet, never for mainnet.
export KEY_NAME="petri-admin"
export KEYRING_BACKEND="test"

# ---- market parameters ----
# A real osmo-test-5 governance proposal in (or past) its voting period, so the vote gate
# has something to read. Find one:  osmosisd query gov proposals --status voting_period --node $RPC
export PROPOSAL_ID="1"
# Betting close, unix seconds. Default in deploy.sh is now+1h if unset.
# export BETTING_CLOSE="1750000000"

# Set after deploy.sh prints it:
# export CONTRACT="osmo1..."
